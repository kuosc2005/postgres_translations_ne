#: pg_waldump.c:760
#, c-format
msgid ""
"Usage:\n"
msgstr ""
"Usage:\n"

#: pg_waldump.c:761
#, c-format
msgid ""
"  %s [OPTION]... [STARTSEG [ENDSEG]]\n"
msgstr ""
"[REVIEW: untranslated]   %s [OPTION]... [STARTSEG [ENDSEG]]\n"

#: pg_waldump.c:762
#, c-format
msgid ""
"\n"
"Options:\n"
msgstr ""
"\n"
"Options:\n"

#: pg_waldump.c:763
#, c-format
msgid ""
"  -b, --bkp-details      output detailed information about backup blocks\n"
msgstr ""
"[REVIEW: backup, lock]   -b, --bkp-details      output विवरणed information about backup blocks\n"

#: pg_waldump.c:764
#, c-format
msgid ""
"  -B, --block=N          with --relation, only show records that modify block N\n"
msgstr ""
"[REVIEW: relation, lock; untranslated]   -B, --block=N          with --relation, only show records that modify block N\n"

#: pg_waldump.c:765
#, c-format
msgid ""
"  -e, --end=RECPTR       stop reading at WAL location RECPTR\n"
msgstr ""
"[REVIEW: WAL; untranslated]   -e, --end=RECPTR       stop reading at WAL location RECPTR\n"

#: pg_waldump.c:766
#, c-format
msgid ""
"  -f, --follow           keep retrying after reaching end of WAL\n"
msgstr ""
"[REVIEW: WAL; untranslated]   -f, --follow           keep retrying after reaching end of WAL\n"

#: pg_waldump.c:767
#, c-format
msgid ""
"  -F, --fork=FORK        only show records that modify blocks in fork FORK;\n"
"                         valid names are main, fsm, vm, init\n"
msgstr ""
"[REVIEW: lock; untranslated]   -F, --fork=FORK        only show records that modify blocks in fork FORK;\n"
"                         valid नामs are main, fsm, vm, init\n"

#: pg_waldump.c:769
#, c-format
msgid ""
"  -n, --limit=N          number of records to display\n"
msgstr ""
"[REVIEW: untranslated]   -n, --limit=N          number of records to display\n"

#: pg_waldump.c:770
#, c-format
msgid ""
"  -p, --path=PATH        directory in which to find WAL segment files or a\n"
"                         directory with a ./pg_wal that contains such files\n"
"                         (default: current directory, ./pg_wal, $PGDATA/pg_wal)\n"
msgstr ""
"[REVIEW: WAL; sentence]   -p, --path=PATH        directory in which to find WAL segment फाइलs or a\n"
"[REVIEW: WAL]                          directory with a ./pg_wal that contains such फाइलs\n"
"[REVIEW: WAL; untranslated]                          (default: current directory, ./pg_wal, $PGDATA/pg_wal)\n"

#: pg_waldump.c:773
#, c-format
msgid ""
"  -q, --quiet            do not print any output, except for errors\n"
msgstr ""
"  -q, --quiet            do not print any output, except for त्रुटिs\n"

#: pg_waldump.c:774
#, c-format
msgid ""
"  -r, --rmgr=RMGR        only show records generated by resource manager RMGR;\n"
"                         use --rmgr=list to list valid resource manager names\n"
msgstr ""
"[REVIEW: untranslated]   -r, --rmgr=RMGR        only show records generated by resource manager RMGR;\n"
"                         use --rmgr=list to list valid resource manager नामs\n"

#: pg_waldump.c:776
#, c-format
msgid ""
"  -R, --relation=T/D/R   only show records that modify blocks in relation T/D/R\n"
msgstr ""
"[REVIEW: relation, lock; untranslated]   -R, --relation=T/D/R   only show records that modify blocks in relation T/D/R\n"

#: pg_waldump.c:777
#, c-format
msgid ""
"  -s, --start=RECPTR     start reading at WAL location RECPTR\n"
msgstr ""
"[REVIEW: WAL; untranslated]   -s, --start=RECPTR     start reading at WAL location RECPTR\n"

#: pg_waldump.c:778
#, c-format
msgid ""
"  -t, --timeline=TLI     timeline from which to read WAL records\n"
"                         (default: 1 or the value used in STARTSEG)\n"
msgstr ""
"[REVIEW: timeline, WAL]   -t, --timeline=TLI     timeलाइन from which to read WAL records\n"
"[REVIEW: untranslated]                          (default: 1 or the value used in STARTSEG)\n"

#: pg_waldump.c:780
#, c-format
msgid ""
"  -V, --version          output version information, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -V, --version          output version information, then exit\n"

#: pg_waldump.c:781
#, c-format
msgid ""
"  -w, --fullpage         only show records with a full page write\n"
msgstr ""
"[REVIEW: untranslated]   -w, --fullpage         only show records with a full page write\n"

#: pg_waldump.c:782
#, c-format
msgid ""
"  -x, --xid=XID          only show records with transaction ID XID\n"
msgstr ""
"[REVIEW: transaction; untranslated]   -x, --xid=XID          only show records with transaction ID XID\n"

#: pg_waldump.c:783
#, c-format
msgid ""
"  -z, --stats[=record]   show statistics instead of records\n"
"                         (optionally, show per-record statistics)\n"
msgstr ""
"[REVIEW: untranslated]   -z, --stats[=record]   show statistics instead of records\n"
"[REVIEW: untranslated]                          (optionally, show per-record statistics)\n"

#: pg_waldump.c:785
#, c-format
msgid ""
"  --save-fullpage=DIR    save full page images to DIR\n"
msgstr ""
"[REVIEW: untranslated]   --save-fullpage=DIR    save full page images to DIR\n"

#: pg_waldump.c:786
#, c-format
msgid ""
"  -?, --help             show this help, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -?, --help             show this help, then exit\n"

