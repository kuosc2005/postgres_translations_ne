"[REVIEW: untranslated] %s is the PostgreSQL embedded SQL preprocessor for C programs.\n"
"\n"

#: ecpg.c:39
#, c-format
msgid ""
"Usage:\n"
"  %s [OPTION]... FILE...\n"
"\n"
msgstr ""
"Usage:\n"
"  %s [OPTION]... FILE...\n"
"\n"

#: ecpg.c:42
#, c-format
msgid ""
"Options:\n"
msgstr ""
"Options:\n"

#: ecpg.c:43
#, c-format
msgid ""
"  -c             automatically generate C code from embedded SQL code;\n"
"                 this affects EXEC SQL TYPE\n"
msgstr ""
"[REVIEW: untranslated]   -c             automatically generate C code from embedded SQL code;\n"
"[REVIEW: untranslated]                  this affects EXEC SQL TYPE\n"

#: ecpg.c:45
#, c-format
msgid ""
"  -C MODE        set compatibility mode; MODE can be one of\n"
"                 \"INFORMIX\", \"INFORMIX_SE\", \"ORACLE\"\n"
msgstr ""
"[REVIEW: untranslated]   -C MODE        set compatibility mode; MODE can be one of\n"
"[REVIEW: untranslated]                  \"INFORMIX\", \"INFORMIX_SE\", \"ORACLE\"\n"

#: ecpg.c:48
#, c-format
msgid ""
"  -d             generate parser debug output\n"
msgstr ""
"[REVIEW: untranslated]   -d             generate parser debug output\n"

#: ecpg.c:50
#, c-format
msgid ""
"  -D SYMBOL      define SYMBOL\n"
msgstr ""
"[REVIEW: untranslated]   -D SYMBOL      define SYMBOL\n"

#: ecpg.c:51
#, c-format
msgid ""
"  -h             parse a header file, this option includes option \"-c\"\n"
msgstr ""
"  -h             parse a header फाइल, this option includes option \"-c\"\n"

#: ecpg.c:52
#, c-format
msgid ""
"  -i             parse system include files as well\n"
msgstr ""
"  -i             parse system include फाइलs as well\n"

#: ecpg.c:53
#, c-format
msgid ""
"  -I DIRECTORY   search DIRECTORY for include files\n"
msgstr ""
"  -I DIRECTORY   search DIRECTORY for include फाइलs\n"

#: ecpg.c:54
#, c-format
msgid ""
"  -o OUTFILE     write result to OUTFILE\n"
msgstr ""
"[REVIEW: untranslated]   -o OUTFILE     write result to OUTFILE\n"

#: ecpg.c:55
#, c-format
msgid ""
"  -r OPTION      specify run-time behavior; OPTION can be:\n"
"                 \"no_indicator\", \"prepare\", \"questionmarks\"\n"
msgstr ""
"[REVIEW: untranslated]   -r OPTION      specify run-time behavior; OPTION can be:\n"
"[REVIEW: untranslated]                  \"no_indicator\", \"prepare\", \"questionmarks\"\n"

#: ecpg.c:57
#, c-format
msgid ""
"  --regression   run in regression testing mode\n"
msgstr ""
"[REVIEW: untranslated]   --regression   run in regression testing mode\n"

#: ecpg.c:58
#, c-format
msgid ""
"  -t             turn on autocommit of transactions\n"
msgstr ""
"[REVIEW: transaction; untranslated]   -t             turn on autocommit of transactions\n"

#: ecpg.c:59
#, c-format
msgid ""
"  -V, --version  output version information, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -V, --version  output version information, then exit\n"

#: ecpg.c:60
#, c-format
msgid ""
"  -?, --help     show this help, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -?, --help     show this help, then exit\n"

#: ecpg.c:61
#, c-format
msgid ""
"\n"
"If no output file is specified, the name is formed by adding .c to the\n"
