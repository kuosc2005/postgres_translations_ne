#: check.c:111
msgid "Checking for system-defined composite types in user tables"
msgstr "Checking for system-defined composite types in प्रयोगकर्ता tables"

#: check.c:118
msgid ""
"Your installation contains system-defined composite types in user tables.\n"
"These type OIDs are not stable across PostgreSQL versions,\n"
"so this cluster cannot currently be upgraded.  You can drop the\n"
"problem columns and restart the upgrade.\n"
msgstr ""
"Your installation contains system-defined composite types in प्रयोगकर्ता tables.\n"
"[REVIEW: OID; untranslated] These type OIDs are not stable across PostgreSQL versions,\n"
"[REVIEW: sentence] so this cluster गर्न सकिँदैन currently be upgraded.  You can drop the\n"
"[REVIEW: untranslated] problem columns and restart the upgrade.\n"

#: check.c:132
msgid "Checking for incompatible \"line\" data type"
msgstr "[REVIEW: untranslated] Checking for incompatible \"line\" data type"

#: check.c:137
msgid ""
"Your installation contains the \"line\" data type in user tables.\n"
"This data type changed its internal and input/output format\n"
"between your old and new versions so this\n"
"cluster cannot currently be upgraded.  You can\n"
"drop the problem columns and restart the upgrade.\n"
msgstr ""
"Your installation contains the \"line\" data type in प्रयोगकर्ता tables.\n"
"[REVIEW: untranslated] This data type changed its internal and input/output format\n"
"[REVIEW: untranslated] between your old and new versions so this\n"
"cluster गर्न सकिँदैन currently be upgraded.  You can\n"
"[REVIEW: untranslated] drop the problem columns and restart the upgrade.\n"

#: check.c:154
msgid "Checking for reg* data types in user tables"
msgstr "Checking for reg* data types in प्रयोगकर्ता tables"

#: check.c:181
msgid ""
"Your installation contains one of the reg* data types in user tables.\n"
"These data types reference system OIDs that are not preserved by\n"
"pg_upgrade, so this cluster cannot currently be upgraded.  You can\n"
"drop the problem columns and restart the upgrade.\n"
msgstr ""
"[REVIEW: sentence] Your installation contains one of the reg* data types in प्रयोगकर्ता tables.\n"
"[REVIEW: OID; untranslated] These data types reference system OIDs that are not preserved by\n"
"pg_upgrade, so this cluster गर्न सकिँदैन currently be upgraded.  You can\n"
"[REVIEW: untranslated] drop the problem columns and restart the upgrade.\n"

#: check.c:193
msgid "Checking for incompatible \"aclitem\" data type"
msgstr "[REVIEW: untranslated] Checking for incompatible \"aclitem\" data type"

#: check.c:198
msgid ""
"Your installation contains the \"aclitem\" data type in user tables.\n"
"The internal format of \"aclitem\" changed in PostgreSQL version 16\n"
"so this cluster cannot currently be upgraded.  You can drop the\n"
"problem columns and restart the upgrade.\n"
msgstr ""
"Your installation contains the \"aclitem\" data type in प्रयोगकर्ता tables.\n"
"[REVIEW: untranslated] The internal format of \"aclitem\" changed in PostgreSQL version 16\n"
"[REVIEW: sentence] so this cluster गर्न सकिँदैन currently be upgraded.  You can drop the\n"
"[REVIEW: untranslated] problem columns and restart the upgrade.\n"

