#: pg_archivecleanup.c:261
#, c-format
msgid ""
"Usage:\n"
msgstr ""
"Usage:\n"

#: pg_archivecleanup.c:262
#, c-format
msgid ""
"  %s [OPTION]... ARCHIVELOCATION OLDESTKEPTWALFILE\n"
msgstr ""
"[REVIEW: archive, WAL; untranslated]   %s [OPTION]... ARCHIVELOCATION OLDESTKEPTWALFILE\n"

#: pg_archivecleanup.c:263
#, c-format
msgid ""
"\n"
"Options:\n"
msgstr ""
"\n"
"Options:\n"

#: pg_archivecleanup.c:264
#, c-format
msgid ""
"  -b, --clean-backup-history  clean up files including backup history files\n"
msgstr ""
"[REVIEW: backup]   -b, --clean-backup-history  clean up फाइलs including backup history फाइलs\n"

#: pg_archivecleanup.c:265
#, c-format
msgid ""
"  -d, --debug                 generate debug output (verbose mode)\n"
msgstr ""
"[REVIEW: untranslated]   -d, --debug                 generate debug output (verbose mode)\n"

#: pg_archivecleanup.c:266
#, c-format
msgid ""
"  -n, --dry-run               dry run, show the names of the files that would be\n"
"                              removed\n"
msgstr ""
"[REVIEW: sentence]   -n, --dry-run               dry run, show the नामs of the फाइलs that would be\n"
"                              removed\n"

#: pg_archivecleanup.c:268
#, c-format
msgid ""
"  -V, --version               output version information, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -V, --version               output version information, then exit\n"

#: pg_archivecleanup.c:269
#, c-format
msgid ""
"  -x, --strip-extension=EXT   strip this extension before identifying files for\n"
"                              clean up\n"
msgstr ""
"[REVIEW: extension]   -x, --strip-extension=EXT   strip this extension before identifying फाइलs for\n"
"                              clean up\n"

#: pg_archivecleanup.c:271
#, c-format
msgid ""
"  -?, --help                  show this help, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -?, --help                  show this help, then exit\n"

#: pg_archivecleanup.c:272
#, c-format
msgid ""
"\n"
"For use as \"archive_cleanup_command\" in postgresql.conf:\n"
"  archive_cleanup_command = 'pg_archivecleanup [OPTION]... ARCHIVELOCATION %%r'\n"
"e.g.\n"
"  archive_cleanup_command = 'pg_archivecleanup /mnt/server/archiverdir %%r'\n"
msgstr ""
"\n"
"[REVIEW: archive; untranslated] For use as \"archive_cleanup_command\" in postgresql.conf:\n"
"[REVIEW: archive; untranslated]   archive_cleanup_command = 'pg_archivecleanup [OPTION]... ARCHIVELOCATION %%r'\n"
"e.g.\n"
"[REVIEW: archive; untranslated]   archive_cleanup_command = 'pg_archivecleanup /mnt/server/archiverdir %%r'\n"

#: pg_archivecleanup.c:277
#, c-format
msgid ""
"\n"
"Or for use as a standalone archive cleaner:\n"
"e.g.\n"
"  pg_archivecleanup /mnt/server/archiverdir 000000010000000000000010.00000020.backup\n"
msgstr ""
"\n"
"[REVIEW: archive; untranslated] Or for use as a standalone archive cleaner:\n"
"e.g.\n"
"[REVIEW: archive, backup; untranslated]   pg_archivecleanup /mnt/server/archiverdir 000000010000000000000010.00000020.backup\n"

