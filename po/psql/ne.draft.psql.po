msgid ""
"  -f, --file=FILENAME      execute commands from file, then exit\n"
msgstr ""
"  -f, --file=FILENAME      execute commands from फाइल, then exit\n"

#: help.c:68
msgid ""
"  -l, --list               list available databases, then exit\n"
msgstr ""
"[REVIEW: untranslated]   -l, --list               list available databases, then exit\n"

#: help.c:69
msgid ""
"  -v, --set=, --variable=NAME=VALUE\n"
