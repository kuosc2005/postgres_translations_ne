"General options:\n"

#: help.c:65
msgid ""
"  -c, --command=COMMAND    run only single command (SQL or internal) and exit\n"
msgstr ""
"[REVIEW: untranslated]   -c, --command=COMMAND    run only single command (SQL or internal) and exit\n"

